generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime? // Soft Delete

  categories            Category[]
  transactions          Transaction[]
  workoutPlans          WorkoutPlan[]
  sessions              WorkoutSession[]
  recurringTransactions RecurringTransaction[]
  tasks                 Task[]
  exercises             Exercise[] // <-- Adicionado para gerenciar exercícios customizados do usuário

  @@index([email, deletedAt])
}

model Category {
  id        String       @id @default(uuid())
  name      String
  type      CategoryType
  userId    String?
  user      User?        @relation(fields: [userId], references: [id])
  deletedAt DateTime? // Soft Delete

  transactions          Transaction[]
  exercises             Exercise[]
  recurringTransactions RecurringTransaction[] // Relacionamento com as recorrências de uma categoria

  @@index([userId, type, deletedAt])
}

enum CategoryType {
  INCOME
  EXPENSE
  FITNESS
}

enum PaymentMethod {
  DEBIT
  CREDIT
}

enum RecurrenceFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  YEARLY
}

model RecurringTransaction {
  id            String              @id @default(uuid())
  amount        Decimal             @db.Decimal(12, 2)
  description   String
  frequency     RecurrenceFrequency
  startDate     DateTime
  endDate       DateTime?
  nextDate      DateTime
  isActive      Boolean             @default(true)
  paymentMethod PaymentMethod       @default(DEBIT)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  deletedAt     DateTime? // Soft Delete

  userId String
  user   User   @relation(fields: [userId], references: [id])

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  transactions Transaction[] // Transações físicas geradas por esta recorrência

  @@index([userId, isActive, nextDate, deletedAt])
}

model Transaction {
  id            String        @id @default(uuid())
  amount        Decimal       @db.Decimal(12, 2)
  description   String?
  date          DateTime      @default(now())
  categoryId    String
  category      Category      @relation(fields: [categoryId], references: [id])
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  paymentMethod PaymentMethod @default(DEBIT)
  deletedAt     DateTime? // Soft Delete

  recurringTransactionId String?
  recurringTransaction   RecurringTransaction? @relation(fields: [recurringTransactionId], references: [id])

  @@index([userId, date, paymentMethod, deletedAt])
}

model WorkoutPlan {
  id        String    @id @default(uuid())
  name      String
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  deletedAt DateTime? // Soft Delete

  exercises WorkoutPlanExercise[]
  sessions  WorkoutSession[]

  @@index([userId, deletedAt])
}

model Exercise {
  id         String   @id @default(uuid())
  name       String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  userId String? // <-- Novo campo
  user   User?   @relation(fields: [userId], references: [id]) // <-- Nova relação

  deletedAt DateTime? // Soft Delete

  setLogs              SetLog[]
  workoutPlanExercises WorkoutPlanExercise[]

  @@index([userId, categoryId, deletedAt])
}

model WorkoutPlanExercise {
  id            String      @id @default(uuid())
  workoutPlanId String
  workoutPlan   WorkoutPlan @relation(fields: [workoutPlanId], references: [id])
  exerciseId    String
  exercise      Exercise    @relation(fields: [exerciseId], references: [id])
  
  targetSets    Int         @default(0) // Quantidade obrigatória de séries recomendada
  targetMinReps Int         @default(0) // Repetições mínimas obrigatórias
  targetMaxReps Int         @default(0) // Repetições máximas obrigatórias

  createdAt     DateTime    @default(now())

  @@unique([workoutPlanId, exerciseId])
  @@index([workoutPlanId])
  @@index([exerciseId])
}

model WorkoutSession {
  id            String      @id @default(uuid())
  workoutPlanId String
  workoutPlan   WorkoutPlan @relation(fields: [workoutPlanId], references: [id])
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  startedAt     DateTime    @default(now())
  finishedAt    DateTime?
  deletedAt     DateTime? // Soft Delete

  setLogs SetLog[]

  @@index([userId, startedAt, deletedAt])
}

model SetLog {
  id               String         @id @default(uuid())
  workoutSessionId String
  workoutSession   WorkoutSession @relation(fields: [workoutSessionId], references: [id])
  exerciseId       String
  exercise         Exercise       @relation(fields: [exerciseId], references: [id])
  reps             Int
  weight           Decimal        @db.Decimal(10, 2)
  toFailure        Boolean        @default(false)
  createdAt        DateTime       @default(now())
  deletedAt        DateTime? // Soft Delete

  @@index([exerciseId, createdAt, deletedAt])
  @@index([workoutSessionId, deletedAt])
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

model Task {
  id          String       @id @default(uuid())
  title       String
  description String?
  priority    TaskPriority @default(MEDIUM)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime? // Soft Delete

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId, priority, deletedAt])
}
