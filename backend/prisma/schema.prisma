generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime? // Soft Delete

  categories   Category[]
  transactions Transaction[]
  assets       Asset[]
  workoutPlans WorkoutPlan[]
  sessions     WorkoutSession[]

  @@index([email, deletedAt])
}

model Category {
  id        String       @id @default(uuid())
  name      String
  type      CategoryType
  userId    String?
  user      User?        @relation(fields: [userId], references: [id])
  deletedAt DateTime? // Soft Delete

  transactions Transaction[]
  exercises    Exercise[]

  @@index([userId, type, deletedAt])
}

enum CategoryType {
  INCOME
  EXPENSE
  FITNESS
}

enum PaymentMethod {
  DEBIT
  CREDIT
}

model Transaction {
  id            String        @id @default(uuid())
  amount        Decimal       @db.Decimal(12, 2)
  description   String?
  date          DateTime      @default(now())
  categoryId    String
  category      Category      @relation(fields: [categoryId], references: [id])
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  paymentMethod PaymentMethod @default(DEBIT)
  deletedAt     DateTime? // Soft Delete

  // Índice otimizado incluindo a busca e ordenação comum com o método de pagamento
  @@index([userId, date, paymentMethod, deletedAt])
}

model Asset {
  id        String    @id @default(uuid())
  name      String
  ticker    String?
  quantity  Decimal   @db.Decimal(12, 4)
  bookValue Decimal   @db.Decimal(12, 2)
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  deletedAt DateTime? // Soft Delete

  @@index([userId, deletedAt])
}

model WorkoutPlan {
  id        String    @id @default(uuid())
  name      String
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  deletedAt DateTime? // Soft Delete

  exercises Exercise[]
  sessions  WorkoutSession[]

  @@index([userId, deletedAt])
}

model Exercise {
  id            String      @id @default(uuid())
  name          String
  categoryId    String
  category      Category    @relation(fields: [categoryId], references: [id])
  workoutPlanId String
  workoutPlan   WorkoutPlan @relation(fields: [workoutPlanId], references: [id])
  deletedAt     DateTime? // Soft Delete

  setLogs SetLog[]

  @@index([workoutPlanId, deletedAt])
}

model WorkoutSession {
  id            String      @id @default(uuid())
  workoutPlanId String
  workoutPlan   WorkoutPlan @relation(fields: [workoutPlanId], references: [id])
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  startedAt     DateTime    @default(now())
  finishedAt    DateTime?
  deletedAt     DateTime? // Soft Delete

  setLogs SetLog[]

  @@index([userId, startedAt, deletedAt])
}

model SetLog {
  id               String         @id @default(uuid())
  workoutSessionId String
  workoutSession   WorkoutSession @relation(fields: [workoutSessionId], references: [id])
  exerciseId       String
  exercise         Exercise       @relation(fields: [exerciseId], references: [id])
  reps             Int
  weight           Decimal        @db.Decimal(10, 2)
  toFailure        Boolean        @default(false)
  createdAt        DateTime       @default(now())
  deletedAt        DateTime? // Soft Delete

  @@index([exerciseId, createdAt, deletedAt])
  @@index([workoutSessionId, deletedAt])
}
